# Supabase (backend do app)
# Crie um projeto em https://supabase.com e rode o schema em schema_banco.sql no SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Opcional: chave da API Groq (para funcionalidades com IA depois)
# Obtenha em: https://console.groq.com/
GROQ_API_KEY=
